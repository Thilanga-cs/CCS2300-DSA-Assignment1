import java.util.*;

/**
 * Module 1: Smart City Route Planner (Beginner-friendly)
 * - Store locations in a BST first
 * - Map them into a Graph (Adjacency List)
 * - BFS (Queue) + DFS (Stack)
 */
public class Main {

    // ---------------- BST (stores location names) ----------------
    static class BSTNode {
        String name;
        BSTNode left, right;

        BSTNode(String name) {
            this.name = name;
        }
    }

    static class LocationBST {
        BSTNode root;

        boolean insert(String name) {
            name = clean(name);
            if (name.isEmpty()) return false;

            if (root == null) {
                root = new BSTNode(name);
                return true;
            }

            BSTNode cur = root;
            while (true) {
                int cmp = name.compareToIgnoreCase(cur.name);
                if (cmp == 0) return false; // already exists
                if (cmp < 0) {
                    if (cur.left == null) { cur.left = new BSTNode(name); return true; }
                    cur = cur.left;
                } else {
                    if (cur.right == null) { cur.right = new BSTNode(name); return true; }
                    cur = cur.right;
                }
            }
        }

        boolean contains(String name) {
            name = clean(name);
            BSTNode cur = root;
            while (cur != null) {
                int cmp = name.compareToIgnoreCase(cur.name);
                if (cmp == 0) return true;
                cur = (cmp < 0) ? cur.left : cur.right;
            }
            return false;
        }

        boolean remove(String name) {
            name = clean(name);
            if (!contains(name)) return false;
            root = removeRec(root, name);
            return true;
        }

        private BSTNode removeRec(BSTNode node, String name) {
            if (node == null) return null;

            int cmp = name.compareToIgnoreCase(node.name);
            if (cmp < 0) node.left = removeRec(node.left, name);
            else if (cmp > 0) node.right = removeRec(node.right, name);
            else {
                // found
                if (node.left == null) return node.right;
                if (node.right == null) return node.left;

                // two children: replace with smallest in right subtree
                BSTNode min = node.right;
                while (min.left != null) min = min.left;
                node.name = min.name;
                node.right = removeRec(node.right, min.name);
            }
            return node;
        }

        void printInOrder() {
            if (root == null) {
                System.out.println("BST is empty.");
                return;
            }
            System.out.println("Locations in BST (sorted):");
            printInOrderRec(root);
            System.out.println();
        }

        private void printInOrderRec(BSTNode node) {
            if (node == null) return;
            printInOrderRec(node.left);
            System.out.println("- " + node.name);
            printInOrderRec(node.right);
        }
    }

    // ---------------- Graph (Adjacency List) ----------------
    static class Graph {
        // location -> set of neighbors (roads)
        Map<String, Set<String>> adj = new HashMap<>();

        boolean addLocation(String name) {
            name = clean(name);
            if (name.isEmpty()) return false;
            if (adj.containsKey(name.toLowerCase())) return false;
            adj.put(name.toLowerCase(), new TreeSet<>(String.CASE_INSENSITIVE_ORDER));
            return true;
        }

        boolean hasLocation(String name) {
            return adj.containsKey(clean(name).toLowerCase());
        }

        boolean removeLocation(String name) {
            name = clean(name);
            String key = name.toLowerCase();
            if (!adj.containsKey(key)) return false;

            // remove this location from all neighbor sets
            for (Set<String> neighbors : adj.values()) {
                neighbors.remove(name);
            }
            adj.remove(key);
            return true;
        }

        boolean addRoad(String a, String b) {
            a = clean(a); b = clean(b);
            if (a.isEmpty() || b.isEmpty()) return false;
            if (a.equalsIgnoreCase(b)) return false;
            if (!hasLocation(a) || !hasLocation(b)) return false;

            adj.get(a.toLowerCase()).add(b);
            adj.get(b.toLowerCase()).add(a);
            return true;
        }

        boolean removeRoad(String a, String b) {
            a = clean(a); b = clean(b);
            if (!hasLocation(a) || !hasLocation(b)) return false;

            boolean r1 = adj.get(a.toLowerCase()).remove(b);
            boolean r2 = adj.get(b.toLowerCase()).remove(a);
            return r1 || r2;
        }

        void displayConnections() {
            if (adj.isEmpty()) {
                System.out.println("No locations in graph.");
                return;
            }
            System.out.println("\n--- Connections ---");
            // show in sorted order by name
            List<String> keys = new ArrayList<>(adj.keySet());
            keys.sort(String.CASE_INSENSITIVE_ORDER);

            for (String key : keys) {
                String displayName = key; // because key is lower-case, we print key
                Set<String> neighbors = adj.get(key);
                System.out.println(displayName + " -> " + (neighbors.isEmpty() ? "[no roads]" : neighbors));
            }
        }

        void bfs(String start) {
            start = clean(start);
            if (!hasLocation(start)) {
                System.out.println("Start location not found.");
                return;
            }

            Queue<String> q = new ArrayDeque<>();
            Set<String> visited = new HashSet<>();

            q.add(start);
            visited.add(start.toLowerCase());

            System.out.print("BFS Order: ");
            while (!q.isEmpty()) {
                String cur = q.poll();
                System.out.print(cur + " ");

                for (String nb : adj.get(cur.toLowerCase())) {
                    String nbKey = nb.toLowerCase();
                    if (!visited.contains(nbKey)) {
                        visited.add(nbKey);
                        q.add(nb);
                    }
                }
            }
            System.out.println();
        }

        void dfs(String start) {
            start = clean(start);
            if (!hasLocation(start)) {
                System.out.println("Start location not found.");
                return;
            }

            Stack<String> st = new Stack<>();
            Set<String> visited = new HashSet<>();

            st.push(start);

            System.out.print("DFS Order: ");
            while (!st.isEmpty()) {
                String cur = st.pop();
                String curKey = cur.toLowerCase();
                if (visited.contains(curKey)) continue;

                visited.add(curKey);
                System.out.print(cur + " ");

                // push neighbors (reverse to make output nicer)
                List<String> nbs = new ArrayList<>(adj.get(curKey));
                Collections.reverse(nbs);
                for (String nb : nbs) {
                    if (!visited.contains(nb.toLowerCase())) st.push(nb);
                }
            }
            System.out.println();
        }
    }

    // ---------------- Helpers ----------------
    static String clean(String s) {
        return (s == null) ? "" : s.trim();
    }

    static int readInt(Scanner sc, String msg, int min, int max) {
        while (true) {
            System.out.print(msg);
            String line = sc.nextLine().trim();
            try {
                int v = Integer.parseInt(line);
                if (v < min || v > max) {
                    System.out.println("Enter a number between " + min + " and " + max + ".");
                } else return v;
            } catch (Exception e) {
                System.out.println("Invalid number. Try again.");
            }
        }
    }

    static String readText(Scanner sc, String msg) {
        while (true) {
            System.out.print(msg);
            String line = sc.nextLine().trim();
            if (!line.isEmpty()) return line;
            System.out.println("Cannot be empty. Try again.");
        }
    }

    // ---------------- Main Menu ----------------
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        LocationBST bst = new LocationBST();
        Graph graph = new Graph();

        while (true) {
            System.out.println("\n==============================");
            System.out.println(" Module 1: Smart City Planner ");
            System.out.println("==============================");
            System.out.println("1. Add Location");
            System.out.println("2. Remove Location");
            System.out.println("3. Add Road");
            System.out.println("4. Remove Road");
            System.out.println("5. Display Connections");
            System.out.println("6. BFS Traverse");
            System.out.println("7. DFS Traverse");
            System.out.println("8. Show Locations (BST)");
            System.out.println("0. Exit");

            int choice = readInt(sc, "Choose: ", 0, 8);

            if (choice == 0) {
                System.out.println("Exit ✅");
                break;
            }

            switch (choice) {
                case 1 -> {
                    String name = readText(sc, "Enter location name: ");
                    boolean okBST = bst.insert(name);
                    if (!okBST) {
                        System.out.println("Location already exists (BST).");
                        break;
                    }
                    boolean okG = graph.addLocation(name);
                    if (okG) System.out.println("Added location: " + name);
                    else System.out.println("Added to BST, but Graph had it already (check duplicates).");
                }
                case 2 -> {
                    String name = readText(sc, "Enter location to remove: ");
                    boolean okBST = bst.remove(name);
                    boolean okG = graph.removeLocation(name);
                    if (okBST || okG) System.out.println("Removed: " + name + " (and related roads).");
                    else System.out.println("Location not found.");
                }
                case 3 -> {
                    String a = readText(sc, "From location: ");
                    String b = readText(sc, "To location: ");
                    boolean ok = graph.addRoad(a, b);
                    System.out.println(ok ? "Road added ✅" : "Failed (locations must exist, and not same).");
                }
                case 4 -> {
                    String a = readText(sc, "From location: ");
                    String b = readText(sc, "To location: ");
                    boolean ok = graph.removeRoad(a, b);
                    System.out.println(ok ? "Road removed ✅" : "No such road / invalid locations.");
                }
                case 5 -> graph.displayConnections();
                case 6 -> {
                    String start = readText(sc, "Start location for BFS: ");
                    graph.bfs(start);
                }
                case 7 -> {
                    String start = readText(sc, "Start location for DFS: ");
                    graph.dfs(start);
                }
                case 8 -> bst.printInOrder();
                default -> System.out.println("Invalid choice.");
            }
        }

        sc.close();
    }
}
